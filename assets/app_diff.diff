+// Utility: Format time to 12-hour
+function formatTime(t) {
+    if (!t) return '---';
+    const [hours, minutes] = t.split(':');
+    let h = parseInt(hours);
+    const ampm = h >= 12 ? 'PM' : 'AM';
+    h = h % 12 || 12;
+    return `${h}:${minutes} ${ampm}`;
+}
